# Local-only test config. Copy to .env (gitignored) — NEVER commit real values.
# In GitHub Actions these come from repo Secrets, not this file.

# --- Postgres ---
DB_HOST=__DB_HOST__
DB_PORT=5432
DB_USER=__DB_USER__
PGPASSWORD=__SET_ME__
PGSSLMODE=require

# --- rclone / Google Drive ---
RCLONE_CONFIG=/abs/path/to/rclone.conf
RCLONE_DEST=__REMOTE__:__BASE_FOLDER__

# --- targets: "dbname:driveSubfolder" pairs, comma-separated ---
DB_TARGETS=__DB_ONE__:__SUB_ONE__,__DB_TWO__:__SUB_TWO__

# --- policy ---
RETENTION_AGE=24h   # prune Drive dumps OLDER THAN this (24h, 7d, 30m...)
LOCAL_KEEP=2
LOCAL_DIR=          # optional; defaults to ./dumps
